<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background: linear-gradient(135deg, #667eea, #764ba2);
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 800px;
            margin: 60px auto;
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.25);
            text-align: center;
        }

        h1 {
            color: #333;
            margin-bottom: 10px;
        }

        p {
            color: #777;
            margin-bottom: 30px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
        }

        .card {
            background: linear-gradient(135deg, #fdfbfb, #ebedee);
            border-radius: 15px;
            padding: 20px;
            text-align: left;
            transition: 0.3s;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

        .card:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }

        .nome {
            font-size: 20px;
            font-weight: bold;
            color: #444;
        }

        .info {
            margin-top: 10px;
            color: #666;
            font-size: 15px;
        }

        .badge {
            display: inline-block;
            margin-top: 10px;
            padding: 5px 10px;
            border-radius: 10px;
            font-size: 12px;
            background: #667eea;
            color: white;
        }

    </style>
</head>
<body>
    <div class="container">
        <h1>🚗 <%= title %></h1>
        <p>Confira nossa lista de carros disponíveis</p>

        <div class="grid">
            <% carros.forEach(function(carro) { %>
                <div class="card">
                    <div class="nome"><%= carro.nome %></div>
                    
                    <div class="info">
                        Marca: <strong><%= carro.marca %></strong><br>
                        Ano: <%= carro.ano %>
                    </div>

                    <div class="badge">Disponível</div>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>