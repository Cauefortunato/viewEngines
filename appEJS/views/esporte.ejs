<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>

    <style>
        body{
            font-family: Arial;
            background:#f4f4f4;
            text-align:center;
        }

        h1{
            color:#333;
        }

        .card{
            background:white;
            width:250px;
            margin:20px auto;
            padding:20px;
            border-radius:10px;
            box-shadow:0 0 10px rgba(0,0,0,0.1);
        }

        .botao{
            display:inline-block;
            margin-top:30px;
            padding:12px 20px;
            background:#007BFF;
            color:white;
            text-decoration:none;
            border-radius:8px;
            font-weight:bold;
            transition:0.3s;
        }

        .botao:hover{
            background:#0056b3;
        }
    </style>
</head>

<body>

<h1><%= title %></h1>

<div class="card">
    <h2>⚽ Futebol</h2>
    <p>Esporte mais popular do mundo.</p>
</div>

<div class="card">
    <h2>🏀 Basquete</h2>
    <p>Jogado com bola e cesta.</p>
</div>

<div class="card">
    <h2>🏐 Vôlei</h2>
    <p>Esporte de rede muito popular no Brasil.</p>
</div>

<a href="/bolas" class="botao">Ir para página de Bolas</a>

</body>
</html>