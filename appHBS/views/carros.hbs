<!DOCTYPE html>
<html>
<head>
    <title>{{title}}</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            background: linear-gradient(135deg, #141e30, #243b55);
            margin: 0;
            padding: 0;
            color: #fff;
        }

        .container {
            max-width: 900px;
            margin: 60px auto;
            padding: 40px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            text-align: center;
        }

        h1 {
            margin-bottom: 10px;
            color: #00e5ff;
        }

        p {
            color: #ccc;
            margin-bottom: 30px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
        }

        .card {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(0,229,255,0.3);
            border-radius: 15px;
            padding: 20px;
            text-align: left;
            transition: 0.3s;
        }

        .card:hover {
            transform: translateY(-5px) scale(1.02);
            border-color: #00e5ff;
            box-shadow: 0 0 15px #00e5ff;
        }

        .nome {
            font-size: 20px;
            font-weight: bold;
            color: #00e5ff;
        }

        .info {
            margin-top: 10px;
            font-size: 15px;
            color: #ddd;
        }

        .badge {
            display: inline-block;
            margin-top: 12px;
            padding: 6px 12px;
            border-radius: 12px;
            font-size: 12px;
            background: #00e5ff;
            color: #000;
            font-weight: bold;
        }

    </style>
</head>
<body>
    <div class="container">
        <h1>🚗 {{title}}</h1>
        <p>Lista de carros disponíveis</p>

        <div class="grid">
            {{#each carros}}
                <div class="card">
                    <div class="nome">{{nome}}</div>

                    <div class="info">
                        Marca: <strong>{{marca}}</strong><br>
                        Ano: {{ano}}
                    </div>

                    <div class="badge">Disponível</div>
                </div>
            {{/each}}
        </div>
    </div>
</body>
</html>