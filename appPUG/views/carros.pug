doctype html
html
  head
    title #{title}
    style.
      body {
        font-family: Arial, Helvetica, sans-serif;
        background: linear-gradient(135deg, #d4fc79, #96e6a1);
        margin: 0;
        padding: 0;
      }

      .container {
        max-width: 900px;
        margin: 60px auto;
        padding: 40px;
        border-radius: 25px;
        background: #ffffff;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        text-align: center;
      }

      h1 {
        color: #2d6a4f;
        margin-bottom: 10px;
      }

      p {
        color: #555;
        margin-bottom: 30px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 25px;
      }

      .card {
        background: #f1faee;
        border-radius: 18px;
        padding: 20px;
        text-align: left;
        transition: 0.3s;
        border-left: 6px solid #52b788;
      }

      .card:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 25px rgba(0,0,0,0.2);
        background: #e9f5ec;
      }

      .nome {
        font-size: 20px;
        font-weight: bold;
        color: #1b4332;
      }

      .info {
        margin-top: 10px;
        font-size: 15px;
        color: #444;
      }

      .badge {
        display: inline-block;
        margin-top: 12px;
        padding: 6px 12px;
        border-radius: 12px;
        font-size: 12px;
        background: #52b788;
        color: white;
        font-weight: bold;
      }

  body
    .container
      h1 🚗 #{title}
      p Lista de carros disponíveis

      .grid
        each carro in carros
          .card
            .nome #{carro.nome}

            .info
              | Marca: 
              strong #{carro.marca}
              br
              | Ano: #{carro.ano}

            .badge Disponível